{
  "name": "xyz",
  "version": "v5.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/geolytix/xyz"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "turbo run dev --filter=@geolytix/xyz-app",
    "dev:auth": "turbo run dev --filter=@geolytix/xyz-auth-app",
    "dev:saml": "turbo run dev --filter=@geolytix/xyz-saml-app",
    "test": "turbo run test",
    "test:xyz": "turbo run test --filter=@geolytix/xyz-app",
    "test:xyz:coverage": "turbo run test:coverage --filter=@geolytix/xyz-app",
    "build": "turbo run build",
    "ui_css": "pnpm exec esbuild --bundle public/css/_ui.css --outfile=public/css/ui.css --external:*.woff2",
    "mapp_css": "pnpm exec esbuild --bundle public/css/_mapp.css --outfile=public/css/mapp.css",
    "generate-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose && jsdoc --configure ./utils/jsdoc_xyz.json --verbose",
    "mapp-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose",
    "xyz-docs": "jsdoc --configure ./utils/jsdoc_xyz.json --verbose",
    "push-env": "node ./utils/sync-vercel-env.js"
  },
  "license": "MIT",
  "dependencies": {
    "@geolytix/mapp": "workspace:*",
    "@geolytix/xyz-auth-app": "workspace:*",
    "@geolytix/xyz-app": "workspace:*",
    "@geolytix/xyz-saml-app": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "clean-jsdoc-theme": "catalog:",
    "dotenv": "catalog:",
    "node-mocks-http": "catalog:",
    "turbo": "catalog:",
    "undici": "catalog:",
    "vitest": "catalog:"
  }
}
